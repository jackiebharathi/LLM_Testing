# LLM Evaluation Framework — Environment Variables
# Copy this file to .env and fill in real values

# ============================================================================
# Groq API (REQUIRED — used for BOTH the LLM under test AND DeepEval metrics)
# Free tier: 30 req/min, very fast
# Get free key at: https://console.groq.com/keys
# ============================================================================

GROQ_API_KEY=gsk_your_groq_api_key_here

# Groq model to use as the LLM under test (default: llama-3.3-70b-versatile)
# Other options: llama-3.1-8b-instant, mixtral-8x7b-32768, gemma2-9b-it
# GROQ_MODEL=llama-3.3-70b-versatile

# Base URL for API integration tests
BASE_URL=https://api.groq.com

# ============================================================================
# Optional: OpenAI API (only needed if you prefer OpenAI as evaluator)
# ============================================================================

# OPENAI_API_KEY=sk_your_openai_api_key_here

# ============================================================================
# Optional: Test environment
# ============================================================================

# Controls threshold strictness: default | strict | relaxed
# TEST_ENV=default
